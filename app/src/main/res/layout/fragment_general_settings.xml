<?xml version="1.0" encoding="utf-8"?>
<!-- 1. 最外层必须是一个 ScrollView，这样内容多了才能滚 -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <!-- 2. ScrollView 内部只能有一个直接子 View，所以用 LinearLayout 包裹 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ 通用设置"
            android:textSize="20sp"
            android:textStyle="bold" />
        <!-- 在通用设置标题下方插入 -->

        <!-- 1. 主任务类型选择 -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="当前执行任务">

            <AutoCompleteTextView
                android:id="@+id/spinner_main_task"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:text="请选择任务" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ====================================================== -->
        <!-- 2. 拍卖行抢拍配置组 (包裹在一个 LinearLayout 中方便控制显隐) -->
        <!-- ====================================================== -->
        <LinearLayout
            android:id="@+id/group_auction_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"> <!-- 默认隐藏 -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="⚖️ 拍卖行抢拍配置"
                android:textStyle="bold"
                android:textColor="@color/purple_500" />

            <!-- 这里放你现有的两个输入框 (价格、数量) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:baselineAligned="false">

                <!-- 目标价格输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="最高购买价">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_max_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="0" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 目标数量输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="最大购买数">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_max_quantity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="0" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="* 设置为 0 表示不限制价格和数量"
                android:textColor="#999999"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- 3. 多角色任务配置组 -->
        <LinearLayout
            android:id="@+id/group_multi_role_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="👥 多角色任务配置"
                android:textStyle="bold"
                android:textColor="@color/purple_500" />

            <!-- 新增：角色数量输入区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="角色总数 (最大 22)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_role_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="2"
                        android:text="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_generate_roles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="生成列表" />
            </LinearLayout>

            <!-- 动态容器 -->
            <LinearLayout
                android:id="@+id/container_roles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
