<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeColor="#DDDDDD"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- 标题栏：开关 + 名称-->
        <RelativeLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- 1. 换成通用的 SwitchCompat -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_role_enable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:checked="true"
                android:clickable="true"
                android:focusable="true"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:text="" />

            <!-- 2. 名字：放在开关右边 -->
            <TextView
                android:id="@+id/tv_role_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@id/switch_role_enable"
                android:text="角色 1"
                android:textColor="@color/purple_500"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layout_tasks_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"> <!-- 默认折叠 -->

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:padding="8dp">

                <CheckBox
                    android:id="@+id/cb_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="日常副本"
                    android:textSize="12sp" />

                <CheckBox
                    android:id="@+id/cb_boss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动BOSS"
                    android:textSize="12sp" />

                <CheckBox
                    android:id="@+id/cb_decompose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分解装备"
                    android:textSize="12sp" />

                <CheckBox
                    android:id="@+id/cb_mail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="领取邮件"
                    android:textSize="12sp" />
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>